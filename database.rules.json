{
  "rules": {
    "unimartListingsV1": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["listedAt", "updatedAt", "status", "sellerUid"]
    },
    "unimartListingsMeta": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "unimartBans": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "unimartAdminV1": {
      "reports": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "unimartSellerWarnings": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null",
        ".indexOn": ["createdAt", "status", "listingId", "reason"]
      }
    },
    "unimartProfiles": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "favorites": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
